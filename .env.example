# Meme Engine - Environment Configuration

# ComfyUI Cloud API Key (required)
# Get from: https://cloud.comfy.org
COMFY_CLOUD_API_KEY=your_comfy_cloud_api_key_here

# Output directory for generated videos
OUTPUT_DIR=./output

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# MCP Server paths (relative to project root)
COMFYUI_MCP_SERVER_PATH=./mcp-servers/comfyui-server
ASSEMBLY_MCP_SERVER_PATH=./mcp-servers/assembly-server
MEME_ENGINE_MCP_SERVER_PATH=./mcp-servers/meme-engine-server

# Optional: Custom ffmpeg path (if not in PATH)
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# Optional: Font path for text overlays (auto-detected if not set)
# FONT_PATH=/System/Library/Fonts/Helvetica.ttc
